APP_NAME="Shams Print CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.ziakhatri.site
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=shams_print_crm
DB_USERNAME=shams
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-me
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=change-redis-me
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

CLOUDINARY_CLOUD_NAME=change-cloud
CLOUDINARY_API_KEY=change-api
CLOUDINARY_API_SECRET=change-secret
CLOUDINARY_URL=cloudinary://change-api:change-secret@change-cloud
